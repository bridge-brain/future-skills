---
---

<section class="relative min-h-[90vh] flex items-center pt-24 pb-16 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-20 right-0 w-[600px] h-[600px] bg-gradient-to-br from-brand-blue/5 via-brand-blue/10 to-transparent rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-to-tr from-brand-navy/5 to-transparent rounded-full blur-3xl"></div>
    <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(rgba(10,22,40,1) 1px, transparent 1px), linear-gradient(90deg, rgba(10,22,40,1) 1px, transparent 1px); background-size: 60px 60px;"></div>
  </div>

  <div class="max-w-5xl mx-auto px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Cover -->
      <div class="flex justify-center lg:justify-end animate-slide-up opacity-0 delay-100">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-brand-blue/20 to-brand-navy/20 rounded-3xl blur-2xl"></div>
          <img
            src="/cover.webp"
            alt="Future Skills – Buchcover"
            class="relative w-64 sm:w-72 lg:w-80 h-auto rounded-2xl shadow-2xl shadow-brand-navy/20"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="lg:order-first">
        <div class="animate-slide-up opacity-0 delay-200">
          <span class="inline-block px-4 py-2 bg-brand-navy/5 text-brand-navy text-sm font-medium rounded-full mb-6">
            Neues Buch
          </span>
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] mb-4 animate-slide-up opacity-0 delay-300">
          <span class="block">FUTURE</span>
          <span class="block text-gradient">SKILLS</span>
        </h1>

        <p class="text-lg text-slate-600 leading-relaxed mb-8 animate-slide-up opacity-0 delay-400">
          7 Schlüsselkompetenzen für mehr Klarheit, Gelassenheit und Handlungsfähigkeit in unsicheren Zeiten
        </p>

        <p class="text-sm font-semibold text-slate-400 uppercase tracking-wider animate-slide-up opacity-0 delay-500">
          Von <span class="text-brand-navy">Niko Kohls</span> · Erscheint im Kösel-Verlag
        </p>
      </div>
    </div>
  </div>
</section>
