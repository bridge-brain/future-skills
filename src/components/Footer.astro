---
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto border-t border-slate-100 bg-slate-50/50">
  <div class="max-w-5xl mx-auto px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div class="flex flex-col gap-4">
        <a href="https://bridge-brain.ai/de">
          <img
            src="/logo.png"
            alt="bridgebrAIn"
            class="h-8 w-auto opacity-80 hover:opacity-100 transition-opacity"
          />
        </a>
        <p class="text-sm text-slate-500">
          © {currentYear} Bridgebrain.AI GmbH. Alle Rechte vorbehalten.
        </p>
      </div>

      <div class="flex flex-col gap-2">
        <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Rechtliches</span>
        <div class="flex gap-6">
          <a
            href="https://bridge-brain.ai/de/imprint"
            class="text-sm text-slate-600 hover:text-brand-navy transition-colors"
          >
            Impressum
          </a>
          <a
            href="https://bridge-brain.ai/de/privacy"
            class="text-sm text-slate-600 hover:text-brand-navy transition-colors"
          >
            Datenschutz
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
